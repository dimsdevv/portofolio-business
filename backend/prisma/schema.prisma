generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Project {
  id          String   @id @default(cuid())
  number      String
  name        String
  slug        String   @unique
  category    String
  year        String
  description String
  thumbnail   String
  tags        String
  url         String
  content     String
  challenge   String?
  approach    String?
  impact      String?
  gallery     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
